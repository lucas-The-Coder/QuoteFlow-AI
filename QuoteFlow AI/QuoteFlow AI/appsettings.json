{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Sqlite": "Data Source=QuoteFlow.db"
  },
  "AuthSettings": {
    "Secret": "your_super_secret_key_at_least_32_characters_long_here",
    "Issuer": "QuoteFlowAI",
    "Audience": "QuoteFlowUsers",
    "ExpiryInMinutes": 60
  },
  "WhatsAppSettings": {
    "PhoneNumberId": "your_phone_number_id",
    "AccessToken": "your_access_token",
    "ApiBaseUrl": "https://graph.facebook.com/v18.0",
    "WebhookVerifyToken": "your_verify_token"
  },
  "EmailSettings": {
    "SmtpServer": "smtp.gmail.com",
    "SmtpPort": 587,
    "SenderEmail": "noreply@yourdomain.com",
    "SenderName": "QuoteFlow AI",
    "Username": "your_email@gmail.com",
    "Password": "your_app_password",
    "EnableSsl": true
  }
}